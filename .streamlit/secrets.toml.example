# Secrets for a Streamlit Community Cloud deployment.
#
# Do NOT commit a real secrets.toml — only this .example is tracked
# (.gitignore excludes .streamlit/secrets.toml). On Streamlit Community Cloud
# you paste these into the app's Settings -> Secrets box; you don't commit a
# file. Locally you don't need this at all — use .env instead.

ANTHROPIC_API_KEY = "sk-ant-..."        # required
GUS_BDL_API_KEY = "..."                 # recommended (free) — district demographics
APP_PASSWORD = "pick-a-strong-secret"   # gates the public app; visitors must enter it
