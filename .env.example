# Copy to `.env` and fill in real values. `.env` is gitignored; this file is not.

# Anthropic API key — used by the agent loop (Claude Sonnet 4.6 + Haiku 4.5).
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Voyage AI API key — used by the RAG layer to embed market-report chunks.
# Get one at https://dash.voyageai.com/api-keys (added in Week 3).
VOYAGE_API_KEY=

# GUS BDL (Bank Danych Lokalnych) API key — used by get_district_demographics
# to pull dzielnica-level population / wage / unemployment from Poland's
# Central Statistical Office. Free registration at https://api.stat.gov.pl/Home/BdlApi
# returns a GUID-formatted key, sent as the X-ClientId header.
GUS_BDL_API_KEY=

# App password — gates the Streamlit web app. Leave blank for local
# development (the gate is open when unset); set it for any public deployment
# so only people you share it with can run analyses.
APP_PASSWORD=

# Local Postgres connection string — used by the pgvector store.
# Default assumes the Homebrew postgresql@17 cluster + the `realestate_agent`
# database created during setup. Override if your setup differs.
DATABASE_URL=postgresql://localhost/realestate_agent
